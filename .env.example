# Telegram Bot API token from @BotFather.
BOT_TOKEN=
OWNER_TELEGRAM_ID=

# Generate:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Main mode. Default is Telegram Business Bot API.
# business - only Telegram Business automation bot
# userbot  - legacy Telethon mode
# both     - Business bot + optional Telethon legacy mode
TELEGRAM_MODE=business

DATABASE_URL=sqlite+aiosqlite:///data/app.db
DATA_DIR=data
MEDIA_DIR=data/media
TIMEZONE=Europe/Moscow

# SAVE MODE
SAVE_MODE_ENABLED=true
SAVE_MEDIA_ENABLED=true
MAX_MEDIA_SIZE_MB=50
SAVE_MEDIA_MAX_MB=50
NOTIFY_DELETES=true
NOTIFY_EDITS=true
SAVE_MODE_NOTIFY_DELETES=true
SAVE_MODE_NOTIFY_EDITS=true
SAVE_MODE_SCOPE=private

# Dot commands / legacy Telethon mode
ENABLE_DOT_COMMANDS=true
ENABLE_GROUP_DOT_COMMANDS=false

# Hard mute
ENABLE_HARD_MUTE=true
HARD_MUTE_DELETE_FOR_EVERYONE=true
ENABLE_GROUP_HARD_MUTE=false

# Repeat / spam alias
ENABLE_SPAM_ALIAS=true
MAX_REPEAT_COUNT=5
REPEAT_DELAY_SECONDS=1.0
ENABLE_GROUP_REPEAT=false

# Cooldowns
DOT_COMMAND_COOLDOWN_SECONDS=30
TYPE_MAX_TEXT_LENGTH=4096
LOVE_ANIMATION_MAX_MESSAGES=5

# LLM
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TRANSCRIBE_MODEL=whisper-1
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Limits
MAX_CONTEXT_MESSAGES=80
MAX_LLM_INPUT_CHARS=12000
MAX_SUMMARY_CHARS=3000
DAILY_LLM_LIMIT=100

# Optional features
AUTO_REPLY_ENABLED=false
AUTO_REPLY_MODE=static
AUTO_REPLY_TEXT=Сейчас не могу ответить, напишу позже.
AUTO_REPLY_COOLDOWN_SECONDS=900
REMINDER_LEAD_MINUTES=[15,60,240,1440]
DIGEST_ENABLED=false
DIGEST_TIME=09:00

# Legacy Telethon settings are entered through /login only when TELEGRAM_MODE=userbot|both.
IGNORE_ARCHIVED_CHATS=true
SYNC_DIALOG_LIMIT=50
SYNC_MESSAGES_PER_CHAT=40
